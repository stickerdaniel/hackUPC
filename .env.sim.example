# Copy to .env.sim and fill in. Used by docker-compose.

# Bearer token Convex actions present when calling POST /runs.
SIM_API_KEY=replace-me

# Convex HTTP action endpoint that ingests ticks. After `bunx convex dev`
# (cloud) or running `bun run dev` (local) this URL is printed in logs.
# Cloud format: https://<deployment>.convex.site/sim-ingest
# Local format: http://host.docker.internal:<convex-http-port>/sim-ingest
CONVEX_INGEST_URL=https://your-deployment.convex.site/sim-ingest

# Shared secret in `x-sim-ingest-secret` header for /sim-ingest auth.
# Must match SIM_INGEST_SECRET set on the Convex deployment.
SIM_INGEST_SECRET=replace-me

# Where the SQLite historian lives inside the container (mounted volume).
HISTORIAN_PATH=/data/historian.sqlite

LOG_LEVEL=INFO
